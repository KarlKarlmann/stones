    private static void exportStormCaller(File folder) {
        JsonObject json = new JsonObject();
        json.addProperty("type", "MILESTONE");
        json.addProperty("name", "Storm Caller");
        json.addProperty("description", "Build up charge with attacks. Release lightning at max charge.");
        JsonArray behaviors = new JsonArray();
        JsonObject beh1 = new JsonObject();
        beh1.addProperty("trigger", "ON_ATTACK");
        JsonArray acts1 = new JsonArray();
        JsonObject act1 = new JsonObject();
        act1.addProperty("type", "stones:math");
        act1.addProperty("variable", "lightning_charge");
        act1.addProperty("operation", "add");
        act1.addProperty("value", 1.0);
        acts1.add(act1);
        beh1.add("actions", acts1);
        behaviors.add(beh1);
        JsonObject beh2 = new JsonObject();
        beh2.addProperty("trigger", "ON_ATTACK");
        JsonArray conds2 = new JsonArray();
        JsonObject cond1 = new JsonObject();
        cond1.addProperty("type", "stones:variable_compare");
        cond1.addProperty("variable", "lightning_charge");
        cond1.addProperty("operator", ">=");
        cond1.addProperty("value", 5.0);
        conds2.add(cond1);
        beh2.add("conditions", conds2);
        JsonArray acts2 = new JsonArray();
        JsonObject act2 = new JsonObject();
        act2.addProperty("type", "stones:explode");
        act2.addProperty("radius", 3.0);
        act2.addProperty("fire", false);
        acts2.add(act2);
        JsonObject act3 = new JsonObject();
        act3.addProperty("type", "stones:apply_effect");
        act3.addProperty("effect", "minecraft:speed");
        act3.addProperty("duration", 100);
        act3.addProperty("amplifier", 1);
        acts2.add(act3);
        JsonObject act4 = new JsonObject();
        act4.addProperty("type", "stones:set_variable");
        act4.addProperty("name", "lightning_charge");
        act4.addProperty("value", 0.0);
        acts2.add(act4);
        beh2.add("actions", acts2);
        behaviors.add(beh2);
        json.add("behaviors", behaviors);
        writeToFile(folder, "milestone_storm_caller.json", json);
    }
    
