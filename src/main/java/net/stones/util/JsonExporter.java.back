package net.stones.util;

import com.google.gson.Gson;
import com.google.gson.GsonBuilder;
import com.google.gson.JsonArray;
import com.google.gson.JsonObject;
import net.minecraftforge.fml.loading.FMLPaths;

import java.io.File;
import java.io.FileWriter;
import java.io.IOException;
import java.nio.file.Path;
import java.nio.file.Paths;

public class JsonExporter {
    
    private static final Gson GSON = new GsonBuilder().setPrettyPrinting().create();
    
    public static void main(String[] args) {
        Path configDir;
        try {
            configDir = FMLPaths.CONFIGDIR.get();
        } catch (Exception e) {
            configDir = Paths.get("run/config");
        }

        Path outputDir = configDir.resolve("stones").resolve("v1").resolve("enchantments");
        File folder = outputDir.toFile();
        if (!folder.exists()) folder.mkdirs();
        
        System.out.println("Exporting to: " + folder.getAbsolutePath());
        
        exportAttributeRune(folder, "minor_armor", "minor", "minecraft:generic.armor", "ADDITION", 1.0, "Rune of Hardness", "Increases Armor rating.");
        exportAttributeRune(folder, "major_wrath", "major", "minecraft:generic.attack_damage", "MULTIPLY_TOTAL", 0.01, "Rune of Wrath", "Scales damage with your level.");
        
        exportDrownedWarrior(folder);
        exportBerserker(folder);
        exportNightHunter(folder);
        exportBloodMage(folder);
        exportStormCaller(folder);
        exportPhoenix(folder);
        exportGladiator(folder);
        exportNecromancer(folder);
        exportGamblersRuin(folder);
        
        System.out.println("Export complete!");
    }

    private static void exportAttributeRune(File folder, String name, String type, String attr, String op, double factor, String displayName, String desc) {
        JsonObject json = new JsonObject();
        json.addProperty("type", type.toUpperCase());
        json.addProperty("attribute", attr);
        json.addProperty("operation", op);
        json.addProperty("factor", factor);
        json.addProperty("name", displayName);
        json.addProperty("description", desc);
        writeToFile(folder, name + ".json", json);
    }

    private static void exportGamblersRuin(File folder) {
        JsonObject json = new JsonObject();
        json.addProperty("type", "MILESTONE");
        json.addProperty("name", "Gambler's Ruin");
        json.addProperty("description", "Deal massive damage (400% + sacrificed level), but sacrifice a random enchantment.");
        
        JsonArray behaviors = new JsonArray();
        JsonObject behavior = new JsonObject();
        behavior.addProperty("trigger", "ON_ATTACK");
        
        // 1. Condition: Hat der Spieler ein Enchantment? (Damit der Bonus nicht "umsonst" ist)
        JsonArray conds = new JsonArray();
        JsonObject c1 = new JsonObject();
        c1.addProperty("type", "stones:has_enchantment");
        c1.addProperty("target", "attacker");
        conds.add(c1);
        behavior.add("conditions", conds);
        
        JsonArray acts = new JsonArray();
        
        // 2. Entfernen & Level speichern
        JsonObject a1 = new JsonObject();
        a1.addProperty("type", "stones:remove_random_enchantment");
        a1.addProperty("save_level_to", "sacrificed_power");
        acts.add(a1);
        
        // 3. Multiplier Damage (400%)
        JsonObject a2 = new JsonObject();
        a2.addProperty("type", "stones:modify_damage");
        a2.addProperty("multiplier", 4.0);
        acts.add(a2);
        
        // 4. Flat Damage (+Level) - Hier nutzen wir das gespeicherte Level für Schaden!
        JsonObject a3 = new JsonObject();
        a3.addProperty("type", "stones:modify_damage");
        a3.addProperty("add_var", "sacrificed_power");
        acts.add(a3);
        
        // 5. Partikel
        JsonObject a4 = new JsonObject();
        a4.addProperty("type", "stones:spawn_particles");
        a4.addProperty("particle", "minecraft:witch");
        a4.addProperty("count", 20);
        acts.add(a4);

        behavior.add("actions", acts);
        behaviors.add(behavior);
        json.add("behaviors", behaviors);
        
        writeToFile(folder, "milestone_gamblers_ruin.json", json);
    }

    private static void exportDrownedWarrior(File folder) {
        JsonObject json = new JsonObject();
        json.addProperty("type", "MILESTONE");
        json.addProperty("name", "Drowned Warrior");
        json.addProperty("description", "Your attacks consume air but deal massive damage. Don't suffocate!");
        JsonArray behaviors = new JsonArray();
        JsonObject bSwing = new JsonObject();
        bSwing.addProperty("trigger", "ON_SWING");
        JsonArray condsSwing = new JsonArray();
        JsonObject cond1 = new JsonObject();
        cond1.addProperty("type", "stones:has_air");
        cond1.addProperty("min", 60); 
        condsSwing.add(cond1);
        bSwing.add("conditions", condsSwing);
        JsonArray actsSwing = new JsonArray();
        JsonObject actAir = new JsonObject();
        actAir.addProperty("type", "stones:modify_air");
        actAir.addProperty("add", -100); 
        actsSwing.add(actAir);
        bSwing.add("actions", actsSwing);
        behaviors.add(bSwing);
        JsonObject bAttack = new JsonObject();
        bAttack.addProperty("trigger", "ON_ATTACK");
        JsonArray condsAttack = new JsonArray();
        JsonObject cond2 = new JsonObject();
        cond2.addProperty("type", "stones:has_air");
        cond2.addProperty("min", 60); 
        condsAttack.add(cond2);
        bAttack.add("conditions", condsAttack);
        JsonArray actsAttack = new JsonArray();
        JsonObject actDmg = new JsonObject();
        actDmg.addProperty("type", "stones:modify_damage");
        actDmg.addProperty("multiplier", 1.5);
        actDmg.addProperty("add", 5.0);
        actsAttack.add(actDmg);
        bAttack.add("actions", actsAttack);
        behaviors.add(bAttack);
        json.add("behaviors", behaviors);
        writeToFile(folder, "milestone_drowned_warrior.json", json);
    }
    
