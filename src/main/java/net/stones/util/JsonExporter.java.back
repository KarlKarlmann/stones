        JsonObject act2 = new JsonObject();
        act2.addProperty("type", "stones:modify_damage");
        act2.addProperty("add", 8.0);
        actions.add(act2);
        JsonObject act3 = new JsonObject();
        act3.addProperty("type", "stones:heal");
        act3.addProperty("amount", -2.0);
        actions.add(act3);
        JsonObject act4 = new JsonObject();
        act4.addProperty("type", "stones:heal");
        act4.addProperty("percent_of_damage", 0.3);
