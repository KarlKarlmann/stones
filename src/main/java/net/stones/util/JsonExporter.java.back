    private static void exportBloodMage(File folder) {
        JsonObject json = new JsonObject();
        json.addProperty("type", "MILESTONE");
        json.addProperty("name", "Blood Mage");
        json.addProperty("description", "Convert health to power. Lifesteal on attacks.");
