        JsonObject behavior = new JsonObject();
        behavior.addProperty("trigger", "ON_ATTACK");
        JsonArray conditions = new JsonArray();
        JsonObject cond1 = new JsonObject();
        cond1.addProperty("type", "stones:health_below");
        cond1.addProperty("percent", 0.95);
        conditions.add(cond1);
        behavior.add("conditions", conditions);
        JsonArray actions = new JsonArray();
        JsonObject act1 = new JsonObject();
        act1.addProperty("type", "stones:set_variable");
        act1.addProperty("name", "blood_cost");
        act1.addProperty("value", 2.0);
